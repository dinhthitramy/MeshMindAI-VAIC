# Database
DATABASE_URL=postgresql://meshmind:password@localhost:5432/meshmind

# Application
APP_URL=http://localhost:3000
AUTH_TRUST_PROXY_HEADERS=false

# Redis
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=mm:development:v1

# Authentication secrets
# Comma-separated key ring. The first key is active; retain old keys until their sessions expire.
SESSION_HMAC_KEYS=k1:replace-with-at-least-32-random-bytes-in-base64
RATE_LIMIT_HMAC_KEY=replace-with-at-least-32-random-bytes-in-base64
RESET_TOKEN_HMAC_KEY=replace-with-at-least-32-random-bytes-in-base64

# Built-in superadmin (not stored in PostgreSQL)
SUPERADMIN_IDENTIFIER=
SUPERADMIN_PASSWORD_HASH=
SUPERADMIN_TOTP_SECRET=
SUPERADMIN_CREDENTIAL_VERSION=1

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
# Use true for implicit TLS, typically on port 465. Other ports use STARTTLS when available.
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="MeshMind <no-reply@example.com>"
